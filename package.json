{
  "name": "@gitforge/cli",
  "version": "0.1.0",
  "description": "Terminal-native management tool for GitForge",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "gitforge": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "tsup",
    "test": "bun test",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Nu11ified/gitforge-cli.git"
  },
  "license": "MIT",
  "keywords": [
    "gitforge",
    "git",
    "cli"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@gitforge/sdk": "^0.1.0",
    "commander": "^12.1.0"
  },
  "optionalDependencies": {
    "stripe": "^20.4.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.10",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
